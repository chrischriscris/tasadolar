---
import Layout from "../layouts/Layout.astro";
import Header from "@/components/Header.astro";
import ExchangeGapCard from "@/components/ExchangeGapCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import RatesList from "@/components/RatesList.astro";
import CurrencyTabs from "@/components/CurrencyTabs.astro";
import ConverterInput from "@/components/ConverterInput.astro";
import { fetchAllRates } from "@/lib/rates";

// All rate fetching + computation lives in src/lib/rates.ts
// See that module for architecture notes and how to modify sources.
const { cards, exchangeGapPercentage, lastUpdatedText } = await fetchAllRates();
---

<Layout>
  <div class="mx-auto flex h-full min-h-0 max-w-md flex-col overflow-hidden">
    <Header />

    <main class="flex min-h-0 flex-1 flex-col gap-4 overflow-hidden p-4">
      <section class="flex min-h-0 flex-1 flex-col gap-4 overflow-hidden">
        <SectionHeader
          title="Tasas de Referencia"
          lastUpdated={lastUpdatedText}
        />
        <div class="min-h-0 flex-1 overflow-y-auto">
          <RatesList rates={cards} />
        </div>
      </section>

      <section class="mt-auto mb-4 flex flex-col gap-3">
        <ExchangeGapCard percentage={exchangeGapPercentage} />
        <CurrencyTabs activeTab="USD" />
        <ConverterInput symbol="$" />
      </section>
    </main>
  </div>
</Layout>

<script>
  const SYMBOLS: Record<string, string> = { USD: "$", EUR: "€", BS: "Bs." };
  const RATE_DECIMALS = 2;

  let activeTab = "USD";

  const input = document.getElementById("converter-input") as HTMLInputElement;
  const symbolEl = document.getElementById("converter-symbol")!;
  const resetButtons = document.querySelectorAll<HTMLButtonElement>(
    "[data-converter-reset]",
  );

  function roundUp(value: number, decimals = RATE_DECIMALS): number {
    if (!isFinite(value)) return 0;
    const factor = 10 ** decimals;
    return Math.ceil(value * factor) / factor;
  }

  // Format a number using dot as thousands separator and comma as decimal separator
  function formatNumber(value: number, decimals: number): string {
    return new Intl.NumberFormat("es-VE", {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    }).format(value);
  }

  // Parse a display string (with dot thousands + comma decimal) back to a JS number
  function parseDisplayValue(str: string): number {
    // Remove thousand separators (dots) and replace comma decimal with dot
    const normalized = str.replace(/\./g, "").replace(",", ".");
    return parseFloat(normalized);
  }

  function getAmount(): number {
    const v = parseDisplayValue(input.value);
    // Empty input falls back to the placeholder value (1)
    return isNaN(v) || v < 0 ? 1 : v;
  }

  function updateRates() {
    const amount = getAmount();
    const rows = document.querySelectorAll<HTMLElement>("[data-rate-row]");

    rows.forEach((row) => {
      const currency = row.getAttribute("data-currency") ?? "USD";
      const baseRate = roundUp(
        parseFloat(row.getAttribute("data-base-rate") ?? "0"),
      );
      const displayUnit = row.getAttribute("data-display-unit") ?? "BS";
      const id = row.getAttribute("data-rate-row")!;
      const valueEl = document.querySelector<HTMLElement>(
        `[data-rate-value="${id}"]`,
      );
      const tooltipEl = document.querySelector<HTMLElement>(
        `[data-rate-tooltip="${id}"]`,
      );
      if (!valueEl) return;

      if (activeTab === "BS") {
        // BS tab: input is bolivars, show how much foreign currency you get
        row.style.display = "";
        const converted = baseRate > 0 ? roundUp(amount / baseRate) : 0;
        const currencySymbol = currency === "EUR" ? "€" : "$";
        const text = `${currencySymbol} ${formatNumber(converted, RATE_DECIMALS)}`;
        valueEl.textContent = text;
        valueEl.title = text;
        if (tooltipEl) tooltipEl.textContent = text;
      } else {
        // USD or EUR tab: only show rows matching the active currency
        if (currency !== activeTab) {
          row.style.display = "none";
          return;
        }
        row.style.display = "";

        if (displayUnit === "USD") {
          const text = `$ ${formatNumber(roundUp(amount * baseRate), RATE_DECIMALS)}`;
          valueEl.textContent = text;
          valueEl.title = text;
          if (tooltipEl) tooltipEl.textContent = text;
          return;
        }

        const text = `Bs. ${formatNumber(roundUp(amount * baseRate), RATE_DECIMALS)}`;
        valueEl.textContent = text;
        valueEl.title = text;
        if (tooltipEl) tooltipEl.textContent = text;
      }
    });
  }

  // Allow only numeric input with one decimal separator (comma), format with dot thousands
  input.addEventListener("input", () => {
    const raw = input.value;
    // Strip everything except digits and comma (comma = decimal separator)
    let cleaned = raw.replace(/[^0-9,]/g, "");
    // Allow only one comma
    const commaIndex = cleaned.indexOf(",");
    if (commaIndex !== -1) {
      cleaned =
        cleaned.slice(0, commaIndex + 1) +
        cleaned.slice(commaIndex + 1).replace(/,/g, "");
    }
    // Format the integer part with dot thousand separators
    const [intPart, decPartRaw] = cleaned.split(",");
    const decPart = decPartRaw ? decPartRaw.slice(0, RATE_DECIMALS) : undefined;
    const formattedInt = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    const formatted =
      decPart !== undefined ? `${formattedInt},${decPart}` : formattedInt;

    // Preserve cursor position relative to end
    const lengthDiff = formatted.length - raw.length;
    const selectionEnd = (input.selectionEnd ?? raw.length) + lengthDiff;

    input.value = formatted;
    input.setSelectionRange(selectionEnd, selectionEnd);

    updateRates();
  });

  // Tab change event from CurrencyTabs
  document.addEventListener("tab-change", (e: Event) => {
    const { tab } = (e as CustomEvent<{ tab: string }>).detail;
    activeTab = tab;
    symbolEl.textContent = SYMBOLS[tab] ?? "$";
    updateRates();
  });

  input.addEventListener("blur", () => {
    if (input.value === "") {
      updateRates();
      return;
    }

    // Re-format on blur to ensure proper display (e.g. add missing thousand dots)
    const v = getAmount();
    if (!isNaN(v) && v >= 0) {
      const raw = input.value;
      const hasDecimal = raw.includes(",");
      const decimalPlaces = hasDecimal
        ? Math.min(raw.split(",")[1].length, RATE_DECIMALS)
        : 0;
      input.value = formatNumber(v, decimalPlaces);
    }
    updateRates();
  });

  resetButtons.forEach((button) => {
    button.addEventListener("click", () => {
      input.value = "";
      input.focus();
      updateRates();
    });
  });

  // Initial render
  updateRates();
</script>
