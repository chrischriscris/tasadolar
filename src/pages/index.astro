---
import Layout from '../layouts/Layout.astro';
import PriceCard from '../components/PriceCard.astro';
import Calculator from '../components/Calculator.astro';
import { fetchBcvRate } from '../lib/bcv';
import { fetchBinanceP2PRate } from '../lib/binance';

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=300, stale-while-revalidate=60'
);

const [bcv, binance] = await Promise.all([
  fetchBcvRate(),
  fetchBinanceP2PRate(),
]);

const bcvFailed = !!bcv.error;
const binanceFailed = !!binance.error;
const anyFailed = bcvFailed || binanceFailed;

const now = new Date().toLocaleString('es-VE', {
  timeZone: 'America/Caracas',
  dateStyle: 'long',
  timeStyle: 'short',
});
---

<Layout>
  <main class="w-full max-w-2xl mx-auto flex flex-col items-center gap-8">
    <header class="text-center space-y-2">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">
        Tasa del <span class="text-primary">Dolar</span>
      </h1>
      <p class="text-muted-foreground text-sm sm:text-base">
        Precio en bolivares (VES)
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full">
      <PriceCard
        rate={bcv}
        label="BCV"
        sublabel="Tasa Oficial"
        variant="bcv"
        id="card-bcv"
      />
      <PriceCard
        rate={binance}
        label="Binance P2P"
        sublabel="USDT / VES (promedio)"
        variant="binance"
        id="card-bin"
      />
    </div>

    {!bcv.error && !binance.error && bcv.price && binance.price && (
      <div id="brecha" class="w-full max-w-md mx-auto">
        <div class="flex items-center justify-center gap-3 rounded-lg border border-border/50 bg-card/50 backdrop-blur-sm px-4 py-3">
          <span class="text-sm text-muted-foreground">Brecha cambiaria</span>
          <span class={`text-lg font-bold tabular-nums ${binance.price > bcv.price ? 'text-destructive' : 'text-primary'}`}>
            {binance.price > bcv.price ? '+' : ''}{(((binance.price - bcv.price) / bcv.price) * 100).toFixed(2)}%
          </span>
        </div>
      </div>
    )}

    <Calculator
      bcvRate={'price' in bcv && bcv.price != null ? bcv.price : null}
      binanceRate={'price' in binance && binance.price != null ? binance.price : null}
    />

    <footer class="text-center text-xs text-muted-foreground space-y-1">
      <p>Actualizado: {now} (hora de Caracas)</p>
      <p>Se actualiza automaticamente cada 5 minutos</p>
    </footer>
  </main>

  {anyFailed && (
    <script
      data-need-bcv={bcvFailed ? 'true' : undefined}
      data-need-bin={binanceFailed ? 'true' : undefined}
      is:inline
    >
      (function () {
        var s = document.currentScript;
        var needBcv = s.getAttribute('data-need-bcv') === 'true';
        var needBin = s.getAttribute('data-need-bin') === 'true';
        if (!needBcv && !needBin) return;

        function fmt(n) {
          return n.toLocaleString('es-VE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function patchCard(id, price) {
          var card = document.getElementById(id);
          if (!card) return;
          var inner = card.querySelector('[data-slot="card-content"]');
          if (!inner) return;
          var isBcv = id === 'card-bcv';
          var color = isBcv ? 'text-primary' : 'text-amber-400';
          inner.innerHTML =
            '<div class="text-center py-2">' +
            '<p class="text-4xl sm:text-5xl font-bold tracking-tight ' + color + '">Bs ' + fmt(price) + '</p>' +
            '<p class="text-xs text-muted-foreground mt-3">hace un momento</p>' +
            '</div>';
        }

        function patchCalc(key, price) {
          var calc = document.getElementById('calc');
          if (!calc) return;
          calc.dataset[key] = String(price);
        }

        function patchBrecha(bcvPrice, binPrice) {
          if (!bcvPrice || !binPrice) return;
          var pct = ((binPrice - bcvPrice) / bcvPrice) * 100;
          var sign = pct > 0 ? '+' : '';
          var color = pct > 0 ? 'text-destructive' : 'text-primary';
          var existing = document.getElementById('brecha');
          if (existing) {
            var span = existing.querySelector('.text-lg');
            if (span) {
              span.className = 'text-lg font-bold tabular-nums ' + color;
              span.textContent = sign + pct.toFixed(2) + '%';
            }
          } else {
            var container = document.querySelector('main');
            var calcEl = document.getElementById('calc');
            if (!container || !calcEl) return;
            var div = document.createElement('div');
            div.id = 'brecha';
            div.className = 'w-full max-w-md mx-auto';
            div.innerHTML =
              '<div class="flex items-center justify-center gap-3 rounded-lg border border-border/50 bg-card/50 backdrop-blur-sm px-4 py-3">' +
              '<span class="text-sm text-muted-foreground">Brecha cambiaria</span>' +
              '<span class="text-lg font-bold tabular-nums ' + color + '">' + sign + pct.toFixed(2) + '%</span>' +
              '</div>';
            container.insertBefore(div, calcEl);
          }
        }

        var only = needBcv && needBin ? '' : needBcv ? '?only=bcv' : '?only=bin';
        fetch('/api/rates' + only)
          .then(function (r) { return r.json(); })
          .then(function (d) {
            var bcvPrice = null;
            var binPrice = null;
            if (needBcv && d.bcv && !d.bcv.error) {
              patchCard('card-bcv', d.bcv.price);
              patchCalc('bcv', d.bcv.price);
              bcvPrice = d.bcv.price;
            }
            if (needBin && d.binance && !d.binance.error) {
              patchCard('card-bin', d.binance.price);
              patchCalc('bin', d.binance.price);
              binPrice = d.binance.price;
            }
            var calc = document.getElementById('calc');
            if (calc) {
              if (!bcvPrice && calc.dataset.bcv) bcvPrice = parseFloat(calc.dataset.bcv);
              if (!binPrice && calc.dataset.bin) binPrice = parseFloat(calc.dataset.bin);
            }
            patchBrecha(bcvPrice, binPrice);
          })
          .catch(function () {});
      })();
    </script>
  )}
</Layout>