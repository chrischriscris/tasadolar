---
import Layout from "../layouts/Layout.astro";
import Header from "@/components/Header.astro";
import ExchangeGapCard from "@/components/ExchangeGapCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import RatesList from "@/components/RatesList.astro";
import CurrencyTabs from "@/components/CurrencyTabs.astro";
import ConverterInput from "@/components/ConverterInput.astro";
import { fetchAllRates } from "@/lib/rates";
import { formatNumber, RATE_DECIMALS } from "@/lib/number-format";

// All rate fetching + computation lives in src/lib/rates.ts
// See that module for architecture notes and how to modify sources.
const { cards, exchangeGapPercentage, lastUpdatedText } = await fetchAllRates();

const bcvUsd = cards.find((card) => card.id === "bcv-usd");
const binanceUsd = cards.find((card) => card.id === "binance-usd");
const bcvEur = cards.find((card) => card.id === "bcv-eur");

const formatRate = (value: number | null | undefined) =>
  value === null || value === undefined
    ? "no disponible"
    : `Bs. ${formatNumber(value, RATE_DECIMALS)}`;

const pageTitle = `Dólar BCV y Binance hoy: USD/USDT a bolívares | TasaDolar`;
const pageDescription = `Convertidor de dólares, USDT y bolívares en Venezuela. Dólar BCV ${formatRate(bcvUsd?.value)}, Binance USDT ${formatRate(binanceUsd?.value)} y euro BCV ${formatRate(bcvEur?.value)}.`;
const siteUrl =
  import.meta.env.PUBLIC_SITE_URL ?? Astro.site?.href ?? Astro.url.origin;
const pageUrl = new URL("/", siteUrl).href;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "TasaDolar",
    url: pageUrl,
    applicationCategory: "FinanceApplication",
    operatingSystem: "Web",
    inLanguage: "es-VE",
    description: pageDescription,
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
    featureList: [
      "Convertidor de USD a bolívares",
      "Convertidor de USDT a bolívares",
      "Convertidor de bolívares a dólares",
      "Tasa dólar BCV",
      "Tasa Binance P2P USDT/VES",
      "Tasa euro BCV",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "¿Cómo convertir dólares a bolívares?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Escribe el monto en USD o USDT en el convertidor y TasaDolar calcula el equivalente en bolívares usando la tasa BCV o Binance disponible.",
        },
      },
      {
        "@type": "Question",
        name: "¿Cómo convertir bolívares a dólares o USDT?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Selecciona BS, introduce el monto en bolívares y el convertidor muestra su equivalente en USD, USDT, BCV y euro cuando las tasas están disponibles.",
        },
      },
      {
        "@type": "Question",
        name: "¿Qué tasas muestra TasaDolar?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "TasaDolar muestra dólar BCV, USDT/VES de Binance P2P, euro BCV, brecha cambiaria y conversiones entre BCV y USDT.",
        },
      },
    ],
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
  tabFiltering
>
  <div class="mx-auto flex h-full min-h-0 max-w-md flex-col overflow-hidden">
    <Header />
    <div
      data-refresh-indicator
      hidden
      role="status"
      aria-live="polite"
      aria-label="Actualizando tasas"
      class="mx-4 flex h-1 overflow-hidden rounded-full bg-white/5"
    >
      <span
        class="animate-sync-bar bg-teal h-full w-1/3 rounded-full shadow-[0_0_18px_rgba(0,212,170,0.85)]"
        aria-hidden="true"></span>
    </div>

    <main class="flex min-h-0 flex-1 flex-col gap-4 overflow-hidden p-4">
      <section class="flex min-h-0 flex-1 flex-col gap-4 overflow-hidden">
        <SectionHeader
          title="Tasas de Referencia"
          lastUpdated={lastUpdatedText}
        />
        <div class="min-h-0 flex-1 overflow-y-auto">
          <RatesList rates={cards} />
        </div>
      </section>

      <section class="mt-auto mb-4 flex flex-col gap-3">
        <ExchangeGapCard percentage={exchangeGapPercentage} />
        <CurrencyTabs activeTab="USD" />
        <ConverterInput symbol="$" />
      </section>
    </main>
  </div>
</Layout>

<script>
  import "@/scripts/converter";
</script>
