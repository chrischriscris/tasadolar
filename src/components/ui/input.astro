---
import { cn } from '@/lib/utils';

interface Props {
  type?: string;
  class?: string;
  placeholder?: string;
  value?: string;
  id?: string;
  inputmode?: string;
  autocomplete?: string;
  maxlength?: string | number;
}

const { 
  type = 'text', 
  class: className, 
  ...props 
} = Astro.props;
---

<input
  type={type}
  data-slot="input"
  class={cn(
    "flex h-9 w-full rounded-lg border border-input bg-transparent px-3 py-1 text-base shadow-sm transition-colors",
    "file:border-0 file:bg-transparent file:text-sm file:font-medium",
    "placeholder:text-muted-foreground",
    "focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring",
    "disabled:cursor-not-allowed disabled:opacity-50",
    "md:text-sm",
    className
  )}
  {...props}
/>