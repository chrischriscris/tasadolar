---
import { Image } from "astro:assets";
import { formatNumber, RATE_DECIMALS } from "@/lib/number-format";
import type { RateCardData } from "@/lib/rates";

interface Props {
  rate: RateCardData;
}

const { rate } = Astro.props;

const getIconUrl = (iconType: string): string => {
  switch (iconType) {
    case "bcv":
      return "https://flagcdn.com/w80/ve.png";
    case "us":
      return "https://flagcdn.com/w80/us.png";
    case "binance":
      return "https://public.bnbstatic.com/20190405/eb2349c3-b2f8-4a93-a286-8f86a62ea9d8.png";
    case "eu":
      return "https://flagcdn.com/w80/eu.png";
    default:
      return "";
  }
};

const iconUrl = getIconUrl(rate.icon);
const fullValueText =
  rate.value === null
    ? "No disponible"
    : `${rate.displayUnit === "BS" ? "Bs." : "$"} ${formatNumber(
        rate.value,
        RATE_DECIMALS,
      )}`;
---

<div
  class="group bg-card hover:bg-card/80 flex items-center gap-4 rounded-2xl p-3 transition-colors"
  data-rate-row={rate.id}
  data-currency={rate.currency}
  data-base-rate={rate.value ?? ""}
  data-display-unit={rate.displayUnit}
  data-rate-available={rate.value !== null ? "true" : "false"}
>
  <div class="flex h-10 w-10 shrink-0 items-center justify-center">
    <div class="h-8 w-8 overflow-hidden rounded-xl">
      <Image
        src={iconUrl}
        alt={rate.icon}
        width={80}
        height={60}
        loading="eager"
        class="h-full w-full scale-125 object-cover"
      />
    </div>
  </div>

  <div class="flex min-w-0 flex-1 flex-col gap-0.5">
    <span class="text-xs font-medium text-white/80">{rate.title}</span>
    <div class="relative">
      <span
        class="text-teal peer block truncate text-xl font-bold"
        data-rate-value={rate.id}
        tabindex="0"
        aria-label={fullValueText}
        title={fullValueText}
      >
        {
          rate.value === null ? (
            "No disponible"
          ) : (
            <>
              {rate.displayUnit === "BS" ? "Bs." : "$"}
              {formatNumber(rate.value, RATE_DECIMALS)}
            </>
          )
        }
      </span>
      <span
        role="tooltip"
        data-rate-tooltip={rate.id}
        class="pointer-events-none absolute bottom-[calc(100%+0.5rem)] left-0 z-10 w-max max-w-52 rounded-md bg-black/90 px-2 py-1 text-[11px] font-medium tracking-normal text-white/90 opacity-0 transition-opacity duration-150 peer-hover:opacity-100 peer-focus:opacity-100"
      >
        {fullValueText}
      </span>
    </div>
  </div>
</div>
