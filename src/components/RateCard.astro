---
interface Rate {
  id: string;
  title: string;
  value: number;
  change: number;
  icon: "bcv" | "us" | "binance" | "eu";
  currency: "USD" | "EUR" | "BS";
}

interface Props {
  rates?: Rate[];
}

const defaultRates: Rate[] = [
  {
    id: "bcv-usd",
    title: "Tasa BCV",
    value: 36.45,
    change: 0.05,
    icon: "bcv",
    currency: "USD",
  },
  {
    id: "binance-usd",
    title: "Tasa Binance (USDT)",
    value: 39.15,
    change: -0.15,
    icon: "binance",
    currency: "USD",
  },
  {
    id: "bcv-eur",
    title: "Tasa Euro BCV",
    value: 38.9,
    change: 0.0,
    icon: "eu",
    currency: "EUR",
  },
];

const { rates = defaultRates } = Astro.props;

const getIconUrl = (iconType: string): string => {
  switch (iconType) {
    case "bcv":
      return "https://flagcdn.com/w80/ve.png";
    case "us":
      return "https://flagcdn.com/w80/us.png";
    case "binance":
      return "https://public.bnbstatic.com/20190405/eb2349c3-b2f8-4a93-a286-8f86a62ea9d8.png";
    case "eu":
      return "https://flagcdn.com/w80/eu.png";
    default:
      return "";
  }
};
---

<div id="rate-card" class="flex flex-col gap-3">
  {
    rates.map((rate) => {
      const isPositive = rate.change > 0;
      const isNeutral = rate.change === 0;
      const iconUrl = getIconUrl(rate.icon);

      return (
        <div
          class="group bg-card hover:bg-card/80 flex items-center gap-4 rounded-2xl p-3 transition-colors"
          data-rate-row={rate.id}
          data-currency={rate.currency}
          data-base-rate={rate.value}
        >
          <div class="flex h-10 w-10 shrink-0 items-center justify-center">
            <img
              src={iconUrl}
              alt={rate.icon}
              class="h-8 w-8 rounded-xl object-cover"
            />
          </div>

          <div class="flex flex-1 flex-col gap-0.5">
            <span class="text-xs font-medium text-white/80">{rate.title}</span>
            <span class="text-teal text-xl font-bold" data-rate-value={rate.id}>
              Bs. {rate.value.toFixed(2)}
            </span>
          </div>

          <div class="flex flex-col items-end gap-0.5">
            <span
              class={`text-sm font-semibold ${isNeutral ? "text-white/60" : isPositive ? "text-teal" : "text-negative"}`}
            >
              {isPositive ? "+" : ""}
              {rate.change.toFixed(2)}%
            </span>
          </div>
        </div>
      );
    })
  }
</div>
