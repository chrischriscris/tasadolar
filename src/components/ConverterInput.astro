---
import { Undo2 } from "lucide-react";

interface Props {
  symbol?: string;
}

const { symbol = "$" } = Astro.props;
---

<div class="bg-card flex items-center rounded-2xl p-3">
  <span id="converter-symbol" class="pr-3 text-xl font-light text-white/60"
    >{symbol}</span
  >
  <div class="min-w-0 flex-1 overflow-hidden">
    <input
      id="converter-input"
      type="text"
      inputmode="decimal"
      placeholder="1.00"
      autofocus
      class="w-full min-w-0 bg-transparent text-xl font-bold text-white outline-none placeholder:text-white/30"
    />
  </div>
  <span aria-hidden="true" class="h-5 w-px bg-white/20"></span>
  <button
    type="button"
    class="rounded-full p-1.5 text-white/60 transition-colors hover:text-white"
    data-converter-reset
    aria-label="Revertir monto"
    title="Revertir"
  >
    <Undo2 size={16} aria-hidden="true" />
  </button>
</div>
