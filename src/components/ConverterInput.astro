---
interface Props {
  symbol?: string;
  value?: string;
}

const { symbol = "$", value = "1.00" } = Astro.props;
---

<div class="bg-card flex items-center gap-4 rounded-2xl p-3">
  <span class="text-xl font-light text-white/60">{symbol}</span>
  <input
    type="text"
    value={value}
    readonly
    class="flex-1 bg-transparent text-xl font-bold text-white outline-none"
  />
</div>
