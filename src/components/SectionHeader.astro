---
interface Props {
  title: string;
  lastUpdated?: string;
}

const { title, lastUpdated = "Actualizado hace 5m" } = Astro.props;
---

<div class="flex items-center justify-between">
  <h2 class="text-lg font-bold text-white">{title}</h2>
  <span class="text-sm text-white/50">{lastUpdated}</span>
</div>
