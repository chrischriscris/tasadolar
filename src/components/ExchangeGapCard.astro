---
interface Props {
  percentage: number;
  change: number;
  label?: string;
  description?: string;
}

const {
  percentage = 7.42,
  change = 0.12,
  label = "BRECHA CAMBIARIA",
  description = "Diferencia entre BCV y Paralelo",
} = Astro.props;

const isPositive = change >= 0;
---

<div
  class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-teal/10 via-teal/5 to-transparent p-6"
>
  <div class="absolute right-0 top-0 h-full w-1/2 opacity-20">
    <svg viewBox="0 0 200 100" class="h-full w-full" preserveAspectRatio="none">
      <path
        d="M0,80 Q50,60 80,50 T140,30 T200,10"
        stroke="currentColor"
        stroke-width="3"
        fill="none"
        class="text-teal"></path>
      <path
        d="M180,10 L200,10 L200,30"
        stroke="currentColor"
        stroke-width="3"
        fill="none"
        class="text-teal"></path>
    </svg>
  </div>

  <div class="relative z-10">
    <p class="text-xs font-semibold tracking-wider text-teal/80">{label}</p>

    <div class="mt-2 flex items-baseline gap-3">
      <span class="text-5xl font-bold tracking-tight text-white"
        >{percentage.toFixed(2)}%</span
      >
      <span
        class={`flex items-center text-sm font-medium ${isPositive ? "text-teal" : "text-negative"}`}
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          class={`mr-0.5 ${isPositive ? "" : "rotate-180"}`}
        >
          <path d="M7 14l5-5 5 5z" fill="currentColor"></path>
        </svg>
        {isPositive ? "+" : ""}{change.toFixed(2)}%
      </span>
    </div>

    <p class="mt-2 text-sm text-white/60">{description}</p>
  </div>
</div>
