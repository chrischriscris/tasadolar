---
import Card from './ui/card.astro';
import CardHeader from './ui/card-header.astro';
import CardTitle from './ui/card-title.astro';
import CardContent from './ui/card-content.astro';

interface Props {
  bcvRate: number | null;
  binanceRate: number | null;
}

const { bcvRate, binanceRate } = Astro.props;
---

<section
  id="calc"
  class="w-full max-w-md mx-auto"
  data-bcv={bcvRate ?? ''}
  data-bin={binanceRate ?? ''}
>
  <Card class="bg-card/50 backdrop-blur-sm border-border/50">
    <CardHeader class="pb-3">
      <CardTitle class="text-center text-base">Calculadora</CardTitle>
    </CardHeader>
    
    <CardContent class="space-y-4">
      <div class="flex justify-center">
        <div class="inline-flex rounded-lg border border-border p-1 bg-muted/30">
          <button
            id="btn-usd"
            type="button"
            class="mode-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all bg-primary text-primary-foreground"
          >
            $ → Bs
          </button>
          <button
            id="btn-bs"
            type="button"
            class="mode-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all text-muted-foreground hover:text-foreground"
          >
            Bs → $
          </button>
          <button
            id="btn-compare"
            type="button"
            class="mode-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all text-muted-foreground hover:text-foreground"
          >
            $ → $
          </button>
        </div>
      </div>

      <div class="relative">
        <span
          id="input-symbol"
          class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground font-medium text-sm"
        >$</span>
        <input
          id="calc-input"
          type="text"
          inputmode="decimal"
          autocomplete="off"
          maxlength="19"
          placeholder="0.00"
          class="flex h-11 w-full rounded-lg border border-input bg-background px-3 py-2 text-lg font-semibold pl-8 ring-offset-background transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
        />
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div class="rounded-lg border border-primary/20 bg-primary/5 p-4 text-center">
          <p id="label-bcv" class="text-[10px] uppercase tracking-wider text-muted-foreground mb-1.5">BCV</p>
          <p id="res-bcv" class="text-lg font-bold text-primary tabular-nums truncate">—</p>
        </div>
        <div class="rounded-lg border border-amber-500/20 bg-amber-500/5 p-4 text-center">
          <p id="label-bin" class="text-[10px] uppercase tracking-wider text-muted-foreground mb-1.5">Binance P2P</p>
          <p id="res-bin" class="text-lg font-bold text-amber-400 tabular-nums truncate">—</p>
        </div>
      </div>
    </CardContent>
  </Card>
</section>

<script>
  const $ = (s: string) => document.querySelector(s)!;
  const el = {
    calc: $('#calc') as HTMLElement,
    input: $('#calc-input') as HTMLInputElement,
    symbol: $('#input-symbol') as HTMLElement,
    btnUsd: $('#btn-usd') as HTMLButtonElement,
    btnBs: $('#btn-bs') as HTMLButtonElement,
    btnCompare: $('#btn-compare') as HTMLButtonElement,
    labelBcv: $('#label-bcv') as HTMLElement,
    labelBin: $('#label-bin') as HTMLElement,
    resBcv: $('#res-bcv') as HTMLElement,
    resBin: $('#res-bin') as HTMLElement,
  };

  function rates() {
    const b = el.calc.dataset.bcv;
    const n = el.calc.dataset.bin;
    return {
      bcv: b ? parseFloat(b) : NaN,
      bin: n ? parseFloat(n) : NaN,
    };
  }

  let mode: 'usd' | 'bs' | 'compare' = 'usd';

  const fmt = (n: number, decimals = 2) =>
    n.toLocaleString('es-VE', {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    });

  const activeClass = 'bg-primary text-primary-foreground';
  const inactiveClass = 'text-muted-foreground hover:text-foreground';

  function setMode(m: 'usd' | 'bs' | 'compare') {
    mode = m;
    const buttons = [el.btnUsd, el.btnBs, el.btnCompare];
    buttons.forEach(btn => {
      btn.className = `mode-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all ${inactiveClass}`;
    });

    if (m === 'usd') {
      el.symbol.textContent = '$';
      el.input.placeholder = '0.00';
      el.btnUsd.className = `mode-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all ${activeClass}`;
      el.labelBcv.textContent = 'BCV';
      el.labelBin.textContent = 'Binance P2P';
    } else if (m === 'bs') {
      el.symbol.textContent = 'Bs';
      el.input.placeholder = '0,00';
      el.btnBs.className = `mode-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all ${activeClass}`;
      el.labelBcv.textContent = 'BCV';
      el.labelBin.textContent = 'Binance P2P';
    } else {
      el.symbol.textContent = '$';
      el.input.placeholder = '0.00';
      el.btnCompare.className = `mode-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all ${activeClass}`;
      el.labelBcv.textContent = 'Binance → BCV';
      el.labelBin.textContent = 'BCV → Binance';
    }
    compute();
  }

  const MAX_VALUE = 999_999_999;

  function formatWithThousands(value: string): string {
    const parts = value.split(',');
    let intPart = parts[0].replace(/\./g, '');
    intPart = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    return parts.length > 1 ? `${intPart},${parts[1]}` : intPart;
  }

  function sanitizeInput() {
    const cursor = el.input.selectionStart ?? 0;
    const oldVal = el.input.value;
    let clean = oldVal.replace(/[^\d.,]/g, '');
    const commaIdx = clean.indexOf(',');
    if (commaIdx !== -1) {
      clean = clean.slice(0, commaIdx + 1) + clean.slice(commaIdx + 1).replace(/,/g, '');
    }
    const dotsBefore = (oldVal.slice(0, cursor).match(/\./g) || []).length;
    const formatted = formatWithThousands(clean);
    if (formatted !== oldVal) {
      el.input.value = formatted;
      const dotsBeforeNew = (formatted.slice(0, cursor).match(/\./g) || []).length;
      const newCursor = cursor + (dotsBeforeNew - dotsBefore);
      el.input.selectionStart = el.input.selectionEnd = Math.max(0, newCursor);
    }
  }

  function compute() {
    sanitizeInput();
    const { bcv, bin } = rates();
    const raw = el.input.value.replace(/\./g, '').replace(',', '.');
    const v = parseFloat(raw);
    if (!v || v <= 0 || !isFinite(v)) {
      el.resBcv.textContent = '—';
      el.resBin.textContent = '—';
      return;
    }
    const capped = Math.min(v, MAX_VALUE);
    if (mode === 'usd') {
      el.resBcv.textContent = isNaN(bcv) ? 'N/D' : `Bs ${fmt(capped * bcv)}`;
      el.resBin.textContent = isNaN(bin) ? 'N/D' : `Bs ${fmt(capped * bin)}`;
    } else if (mode === 'bs') {
      el.resBcv.textContent = isNaN(bcv) ? 'N/D' : `$ ${fmt(capped / bcv)}`;
      el.resBin.textContent = isNaN(bin) ? 'N/D' : `$ ${fmt(capped / bin)}`;
    } else {
      if (isNaN(bcv) || isNaN(bin) || bcv === 0 || bin === 0) {
        el.resBcv.textContent = 'N/D';
        el.resBin.textContent = 'N/D';
      } else {
        const binToBcv = (capped * bin) / bcv;
        const bcvToBin = (capped * bcv) / bin;
        el.resBcv.textContent = `$ ${fmt(binToBcv)}`;
        el.resBin.textContent = `$ ${fmt(bcvToBin)}`;
      }
    }
  }

  el.input.addEventListener('input', compute);
  el.btnUsd.addEventListener('click', () => setMode('usd'));
  el.btnBs.addEventListener('click', () => setMode('bs'));
  el.btnCompare.addEventListener('click', () => setMode('compare'));
</script>