---
import { Image } from "astro:assets"

interface Rate {
  title: string
  rate: number
  imageSrc: string
}

const rates: Rate[] = [
  {
    title: "Banco de Venezuela ($)",
    rate: 454.5,
    imageSrc: "https://i.pinimg.com/236x/f1/14/f5/f114f582ea26f0b0c0c0301606ae0a23.jpg",
  },
  {
    title: "Banco de Venezuela (€)",
    rate: 454.5,
    imageSrc: "https://i.pinimg.com/236x/f1/14/f5/f114f582ea26f0b0c0c0301606ae0a23.jpg",
  },
  {
    title: "Binance P2P (USDT)",
    rate: 454.5,
    imageSrc: "https://public.bnbstatic.com/20190405/eb2349c3-b2f8-4a93-a286-8f86a62ea9d8.png",
  },
]
---

<div class="flex w-full max-w-md flex-col gap-6" role="list">
  <div class="group/item-group flex w-full flex-col gap-4">
    {rates.map((rate) => (
      <a
        href="#"
        data-slot="item"
        data-variant="outline"
        role="listitem"
        class="group/item flex w-full flex-wrap items-center gap-3.5 rounded-2xl border border-border px-4 py-3.5 text-sm transition-colors duration-100 outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 hover:bg-muted"
      >
        <div
          data-slot="item-media"
          data-variant="image"
          class="flex shrink-0 items-center justify-center gap-2 size-10 overflow-hidden rounded-lg [&_img]:size-full [&_img]:object-cover group-has-data-[slot=item-description]/item:translate-y-0.5 group-has-data-[slot=item-description]/item:self-start"
        >
          <Image
            src={rate.imageSrc}
            alt={rate.title}
            width={32}
            height={32}
            class="object-cover"
          />
        </div>
        <div
          data-slot="item-content"
          class="flex flex-1 flex-col gap-1"
        >
          <div
            data-slot="item-title"
            class="line-clamp-1 flex w-fit items-center gap-2 text-sm leading-snug font-medium underline-offset-4"
          >
            {rate.rate}
          </div>
          <p
            data-slot="item-description"
            class="line-clamp-2 text-left text-sm font-normal text-muted-foreground [&>a]:underline [&>a]:underline-offset-4 [&>a:hover]:text-primary"
          >
            {rate.title}
          </p>
        </div>
      </a>
    ))}
  </div>
</div>
