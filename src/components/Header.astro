---
interface Props {
  title?: string;
}

const { title = "TasaDolar" } = Astro.props;
---

<header
  class="sticky top-0 z-50 flex h-16 items-center justify-between px-5 backdrop-blur-xl"
>
  <div class="flex items-center gap-3">
    <div
      class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal/10"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="text-teal"
      >
        <path
          d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"
          fill="currentColor"></path>
        <path
          d="M7.5 12.5c0-.55.45-1 1-1h2c.55 0 1 .45 1 1s-.45 1-1 1h-2c-.55 0-1-.45-1-1zm4-3c0-.55.45-1 1-1h2c.55 0 1 .45 1 1s-.45 1-1 1h-2c-.55 0-1-.45-1-1zm-4 6c0-.55.45-1 1-1h2c.55 0 1 .45 1 1s-.45 1-1 1h-2c-.55 0-1-.45-1-1z"
          fill="currentColor"
          opacity="0.7"></path>
        <circle cx="16" cy="10" r="1.5" fill="currentColor"></circle>
      </svg>
    </div>
    <h1 class="text-xl font-bold tracking-tight text-white">{title}</h1>
  </div>
</header>
